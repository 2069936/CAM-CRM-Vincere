# Supabase — copy this file to `.env.local` and fill in your project values.
# Get these from: Supabase Dashboard → Project Settings → API
#
# .env.local is gitignored (never commit real keys). This example IS committed.

# Project URL (required), e.g. https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_URL=

# Publishable key (required) — the primary key the app reads.
# Supabase's newer name for the public/anon key.
VITE_SUPABASE_PUBLISHABLE_KEY=

# Anon key (optional) — legacy fallback, used only if PUBLISHABLE_KEY is unset.
# See src/lib/supabaseClient.js: PUBLISHABLE_KEY || ANON_KEY
VITE_SUPABASE_ANON_KEY=

# Server-only HMAC pepper for enrollment, machine, rate-limit, and device-token digests.
INGEST_TOKEN_PEPPER=

# Durable public pairing limiter (attempts per window and temporary block length).
INGEST_PAIR_RATE_LIMIT_MAX_ATTEMPTS=
INGEST_PAIR_RATE_LIMIT_WINDOW_SECONDS=
INGEST_PAIR_RATE_LIMIT_BLOCK_SECONDS=

# Minimum supported collector version used by server-side update enforcement.
AUTO_COLLECTION_MIN_AGENT_VERSION=

# Minimum interval for unchanged collector heartbeats (defaults to 30 seconds).
AUTO_COLLECTION_HEARTBEAT_MIN_INTERVAL_SECONDS=

# Shared ingest/download limits (defaults: 2 MiB gzip / 16 MiB expanded).
# Valid positive integers are clamped to 32 MiB gzip / 128 MiB expanded;
# the four-CSV ZIP derives its bounded in-memory limits from the expanded cap.
AUTO_COLLECTION_MAX_COMPRESSED_BYTES=
AUTO_COLLECTION_MAX_UNCOMPRESSED_BYTES=

# Bounded ownership lease for one daily-batch processing attempt (default 120s).
AUTO_COLLECTION_PROCESSING_LEASE_SECONDS=
