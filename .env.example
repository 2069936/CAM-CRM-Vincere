# Supabase — copy this file to `.env.local` and fill in your project values.
# Get these from: Supabase Dashboard → Project Settings → API
#
# .env.local is gitignored (never commit real keys). This example IS committed.

# Project URL (required), e.g. https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_URL=

# Publishable key (required) — the primary key the app reads.
# Supabase's newer name for the public/anon key.
VITE_SUPABASE_PUBLISHABLE_KEY=

# Anon key (optional) — legacy fallback, used only if PUBLISHABLE_KEY is unset.
# See src/lib/supabaseClient.js: PUBLISHABLE_KEY || ANON_KEY
VITE_SUPABASE_ANON_KEY=
