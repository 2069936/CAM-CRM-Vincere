<Window x:Class="Vincere.AutoExport.Agent.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Vincere Auto Export Setup"
        Width="960" Height="650" MinWidth="840" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource CanvasBrush}"
        Foreground="{StaticResource TextBrush}"
        FontFamily="Segoe UI Variable Text, Segoe UI">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#111B25" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,0,1,0">
            <Grid Margin="30,28">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <StackPanel>
                    <TextBlock Text="V I N C E R E" Foreground="{StaticResource PrimaryBrush}" FontWeight="Bold" FontSize="12" />
                    <TextBlock Text="Auto Export" FontFamily="Segoe UI Variable Display, Segoe UI" FontWeight="SemiBold" FontSize="26" Margin="0,5,0,0" />
                    <TextBlock Text="Connect this VPS once. Collection runs every trading day." Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" LineHeight="20" Margin="0,10,0,0" />
                </StackPanel>

                <StackPanel Grid.Row="1" VerticalAlignment="Center">
                    <TextBlock Text="C O N N E C T I O N   P A T H" Foreground="{StaticResource MutedBrush}" FontSize="10" FontWeight="SemiBold" Margin="0,0,0,18" />
                    <Grid Margin="4,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="30" Height="30" CornerRadius="15" Background="{StaticResource SuccessBrush}">
                            <TextBlock Text="V" Foreground="#0F1720" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <Border Grid.Column="1" Height="2" Background="{StaticResource LineBrush}" VerticalAlignment="Center" />
                        <Border Grid.Column="2" Width="30" Height="30" CornerRadius="15" Background="{StaticResource InfoBrush}">
                            <TextBlock Text="N" Foreground="#0F1720" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <Border Grid.Column="3" Height="2" Background="{StaticResource LineBrush}" VerticalAlignment="Center" />
                        <Border Grid.Column="4" Width="30" Height="30" CornerRadius="15" Background="{StaticResource PrimaryBrush}">
                            <TextBlock Text="C" Foreground="#0F1720" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </Grid>
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions><ColumnDefinition /><ColumnDefinition /><ColumnDefinition /></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="VPS" FontSize="11" Foreground="{StaticResource MutedBrush}" HorizontalAlignment="Left" />
                        <TextBlock Grid.Column="1" Text="NinjaTrader" FontSize="11" Foreground="{StaticResource MutedBrush}" HorizontalAlignment="Center" />
                        <TextBlock Grid.Column="2" Text="CRM" FontSize="11" Foreground="{StaticResource MutedBrush}" HorizontalAlignment="Right" />
                    </Grid>
                </StackPanel>

                <StackPanel Grid.Row="2">
                    <TextBlock Text="Daily capture" Foreground="{StaticResource MutedBrush}" FontSize="11" />
                    <TextBlock Text="4:45 PM · New York" FontWeight="SemiBold" Margin="0,3,0,0" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="42,30,42,28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="STEP" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" FontSize="11" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding CurrentStep}" Foreground="{StaticResource PrimaryBrush}" FontWeight="Bold" FontSize="16" Margin="8,0,0,0" />
                    <TextBlock Text=" / 4" Foreground="{StaticResource MutedBrush}" FontSize="16" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#342A4A" CornerRadius="10" Padding="9,4" Margin="0,0,10,0" Visibility="{Binding UpdateRequired, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="UPDATE REQUIRED" Foreground="#D8CCFF" FontWeight="SemiBold" FontSize="10" />
                    </Border>
                    <TextBlock Text="{Binding QueueSummary}" Foreground="{StaticResource MutedBrush}" FontSize="12" VerticalAlignment="Center" />
                </StackPanel>
            </Grid>

            <TabControl Grid.Row="1" SelectedIndex="{Binding CurrentStepIndex, Mode=OneWay}" Background="Transparent" BorderThickness="0" Margin="-4,22,-4,10" KeyboardNavigation.TabNavigation="Local">
                <TabControl.Resources>
                    <Style TargetType="TabItem"><Setter Property="Visibility" Value="Collapsed" /></Style>
                </TabControl.Resources>
                <TabItem>
                    <StackPanel Margin="4,10" VerticalAlignment="Center">
                        <TextBlock Text="Checking this VPS" FontFamily="Segoe UI Variable Display, Segoe UI" FontSize="32" FontWeight="SemiBold" />
                        <TextBlock Text="Setup is confirming that the background service is installed and protected." Foreground="{StaticResource MutedBrush}" FontSize="15" TextWrapping="Wrap" Margin="0,12,0,0" />
                        <ProgressBar IsIndeterminate="True" Height="4" Foreground="{StaticResource PrimaryBrush}" Background="{StaticResource RaisedBrush}" Margin="0,32,0,0" />
                    </StackPanel>
                </TabItem>
                <TabItem>
                    <StackPanel Margin="4,10" VerticalAlignment="Center">
                        <TextBlock Text="Connect to the CRM" FontFamily="Segoe UI Variable Display, Segoe UI" FontSize="32" FontWeight="SemiBold" />
                        <TextBlock Text="Paste the one-time code from this client's Profile page." Foreground="{StaticResource MutedBrush}" FontSize="15" Margin="0,10,0,24" />
                        <TextBlock Text="One-time code" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <TextBox Text="{Binding EnrollmentCode, UpdateSourceTrigger=PropertyChanged}" MaxLength="16" FontFamily="Cascadia Mono, Consolas" FontSize="22" CharacterCasing="Upper" AutomationProperties.Name="One-time CRM code" />
                        <Button Content="Connect this VPS" Command="{Binding PairCommand}" HorizontalAlignment="Left" Margin="0,20,0,0" AutomationProperties.Name="Connect this VPS to the CRM" />
                    </StackPanel>
                </TabItem>
                <TabItem>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="4,10">
                            <TextBlock Text="Restart and test NinjaTrader" FontFamily="Segoe UI Variable Display, Segoe UI" FontSize="32" FontWeight="SemiBold" />
                            <TextBlock Text="Close NinjaTrader completely, open it again, connect the trading accounts, then run the test." Foreground="{StaticResource MutedBrush}" FontSize="15" TextWrapping="Wrap" LineHeight="22" Margin="0,10,0,20" />
                            <Border Background="{StaticResource RaisedBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="8" Padding="18">
                                <StackPanel>
                                    <TextBlock Text="Connected client" Foreground="{StaticResource MutedBrush}" FontSize="11" />
                                    <TextBlock Text="{Binding ClientName}" FontSize="18" FontWeight="SemiBold" Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>
                            <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                                <Button Content="Run test capture" Command="{Binding TestCaptureCommand}" AutomationProperties.Name="Run NinjaTrader test capture" />
                            </StackPanel>
                            <Expander Header="Advanced schedule" Foreground="{StaticResource MutedBrush}" Margin="0,22,0,0">
                                <StackPanel Margin="0,14,0,0">
                                    <TextBlock Text="Capture time · New York" FontWeight="SemiBold" />
                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                        <ComboBox ItemsSource="{Binding ScheduleChoices}" SelectedItem="{Binding ScheduleTime}" Width="130" AutomationProperties.Name="Daily New York capture time" />
                                        <Button Content="Save time" Command="{Binding SaveScheduleCommand}" Margin="10,0,0,0" />
                                    </StackPanel>
                                </StackPanel>
                            </Expander>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
                <TabItem>
                    <StackPanel Margin="4,10" VerticalAlignment="Center">
                        <Border Width="58" Height="58" CornerRadius="29" Background="{StaticResource SuccessBrush}" HorizontalAlignment="Left">
                            <TextBlock Text="✓" Foreground="#0F1720" FontSize="30" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="Automatic collection is ready" FontFamily="Segoe UI Variable Display, Segoe UI" FontSize="32" FontWeight="SemiBold" Margin="0,20,0,0" />
                        <TextBlock Text="Keep NinjaTrader open and connected. The service will capture, queue, and upload automatically." Foreground="{StaticResource MutedBrush}" FontSize="15" TextWrapping="Wrap" LineHeight="22" Margin="0,10,0,20" />
                        <Button Content="Create support diagnostics" Command="{Binding CollectDiagnosticsCommand}" Background="{StaticResource RaisedBrush}" Foreground="{StaticResource TextBrush}" HorizontalAlignment="Left" AutomationProperties.Name="Create redacted support diagnostics" />
                        <TextBlock Text="{Binding DiagnosticsPath}" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,10,0,0" />
                    </StackPanel>
                </TabItem>
            </TabControl>

            <Border Grid.Row="2" Background="{StaticResource RaisedBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="8" Padding="14,12">
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                    <Ellipse Width="9" Height="9" Fill="{StaticResource InfoBrush}" VerticalAlignment="Center" Margin="0,0,12,0" />
                    <TextBlock Grid.Column="1" Text="{Binding StatusMessage}" TextWrapping="Wrap" VerticalAlignment="Center" AutomationProperties.LiveSetting="Polite" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
