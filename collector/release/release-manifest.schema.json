{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cam-crm-vincere.vercel.app/schemas/collector-release-manifest-v1.json",
  "title": "Vincere Auto Export release manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "version", "minimumAgentVersion", "minimumSchemaVersion", "publishedAt", "signingThumbprint", "artifacts"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:\\.[0-9]+)?$" },
    "minimumAgentVersion": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:\\.[0-9]+)?$" },
    "minimumSchemaVersion": { "type": "integer", "minimum": 1 },
    "publishedAt": { "type": "string", "format": "date-time" },
    "signingThumbprint": { "type": "string", "pattern": "^[A-F0-9]{40,128}$" },
    "artifacts": {
      "type": "array",
      "minItems": 3,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "url", "sha256", "size"],
        "properties": {
          "name": { "type": "string", "pattern": "^[A-Za-z0-9._-]+$" },
          "url": { "type": "string", "format": "uri", "pattern": "^https://" },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "size": { "type": "integer", "minimum": 1 }
        }
      }
    }
  }
}
